[Unit]
Description=Betwise Gunicorn web server
After=network.target mysql.service

[Service]
User=betwise
Group=betwise
WorkingDirectory=/opt/betwise_backend
EnvironmentFile=/opt/betwise_backend/.env
ExecStart=/opt/betwise_backend/venv/bin/gunicorn config.wsgi:application --bind 0.0.0.0:8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
