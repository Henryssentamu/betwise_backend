[Unit]
Description=Betwise Celery beat scheduler
After=network.target redis-server.service mysql.service

[Service]
User=betwise
Group=betwise
WorkingDirectory=/opt/betwise_backend
EnvironmentFile=/opt/betwise_backend/.env
ExecStart=/opt/betwise_backend/venv/bin/celery -A config beat -l info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
