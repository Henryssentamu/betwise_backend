# Django
DJANGO_SECRET_KEY=change-this-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_NAME=betwise
DB_USER=betwise_user
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=3306

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Pesapal (get these from your Pesapal merchant account)
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_ENVIRONMENT=sandbox
# sandbox or live
PESAPAL_IPN_URL=https://yourdomain.com/api/payments/pesapal/ipn/
# Run `python manage.py register_pesapal_ipn` after setting the above, then paste the printed ipn_id below
PESAPAL_IPN_ID=
PESAPAL_CALLBACK_URL=https://yourdomain.com/payment/complete

# Football-Data.org
FOOTBALL_DATA_API_KEY=your-football-data-org-api-key
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:19006

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
